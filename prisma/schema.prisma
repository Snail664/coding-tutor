generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  auth0_email          String?
  auth0_email_verified Boolean    @default(false)
  auth0_family_name    String?
  auth0_given_name     String?
  auth0_name           String?
  auth0_picture        String?
  auth0_sid            String     @unique
  auth0_sub            String     @id
  isWalkthroughEnabled Boolean    @default(true)
  chats                Chat[]
  Feedback             Feedback[]
}

model Chat {
  dateStarted DateTime      @default(now())
  id          Int           @id @default(autoincrement())
  userId      String
  user        User          @relation(fields: [userId], references: [auth0_sub])
  messages    ChatMessage[]
}

model Feedback {
  id               Int          @id @default(autoincrement())
  userId           String
  LLMOutput        String
  feedbackType     FeedbackType
  createdAt        DateTime     @default(now())
  feedbackText     String
  questionName     String
  systemPromptUsed String
  userPromptUsed   String
  Question         Question     @relation(fields: [questionName], references: [name])
  user             User         @relation(fields: [userId], references: [auth0_sub])
}

model ChatMessage {
  id      Int    @id @default(autoincrement())
  role    String
  content String
  chatId  Int
  chat    Chat   @relation(fields: [chatId], references: [id])
}

model Tag {
  name      String     @id
  questions Question[] @relation("QuestionsOnTags")
}

model Question {
  id            Int                @id @default(autoincrement())
  name          String             @unique
  difficulty    QuestionDifficulty
  content       String             @db.VarChar(10000)
  topics        String[]
  Feedback      Feedback[]
  templateCodes TemplateCode[]
  testCases     TestCase[]
  tags          Tag[]              @relation("QuestionsOnTags")
}

model TemplateCode {
  id         Int          @id @default(autoincrement())
  code       String
  language   LanguageName
  questionId Int
  question   Question     @relation(fields: [questionId], references: [id])
}

model TestCase {
  id             Int      @id @default(autoincrement())
  input          String
  expectedOutput String
  description    String
  questionId     Int
  question       Question @relation(fields: [questionId], references: [id])
}

enum FeedbackType {
  hint
  chat
  general
}

enum QuestionDifficulty {
  easy
  medium
  hard
}

enum LanguageName {
  javascript
  python
  typescript
  java
  cpp
}
