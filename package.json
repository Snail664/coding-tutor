{
  "name": "coding-tutor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "postinstall": "prisma generate",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "prisma:migrate:dev": "dotenv -e .env.development -- npx prisma migrate dev --name",
    "prisma:migrate:deploy": "dotenv -e .env.production -- npx prisma migrate deploy",
    "db:seed:dev": "dotenv -e .env.development -- ts-node --files --project tsconfig.seed.json prisma/seed.ts",
    "db:seed:prod": "dotenv -e .env.production -- ts-node --files --project tsconfig.seed.json prisma/seed.ts"
  },
  "dependencies": {
    "@auth0/nextjs-auth0": "^3.5.0",
    "@monaco-editor/react": "^4.6.0",
    "@prisma/client": "^6.0.1",
    "@radix-ui/react-dialog": "^1.1.3",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.3",
    "@reduxjs/toolkit": "^2.4.0",
    "@types/dom-speech-recognition": "^0.0.4",
    "@upstash/redis": "^1.34.3",
    "axios": "^1.7.7",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "constrained-editor-plugin": "^1.3.0",
    "lucide-react": "^0.439.0",
    "next": "14.2.8",
    "next-themes": "^0.4.4",
    "openai": "^4.58.1",
    "prisma": "^6.0.1",
    "raw-loader": "^4.0.2",
    "react": "^18",
    "react-dom": "^18",
    "react-joyride": "^2.9.3",
    "react-markdown": "^9.0.1",
    "react-redux": "^9.1.2",
    "react-resizable": "^3.0.5",
    "tailwind-merge": "^2.5.2",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/react-resizable": "^3.0.8",
    "dotenv-cli": "^8.0.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.8",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
